# Rename this file to ".env", set apporpriate file permissions (0600) and fill in all fields based on your setup
# Or directly inject env vars into the process 

# Public-facing base URL - what browsers use to reach the app
SERVER_URL=http://localhost:8080
SERVER_PORT=8080 # defaults to 8080 for TLS_MODE=off, 443 for on
# TLS mode
TLS_MODE=off # off (default, use a reverse proxy), on (provide cert/key paths)
# Only needed when TLS_MODE=on:
# TLS_CERT_FILE=/etc/ssl/certs/notifier.crt
# TLS_KEY_FILE=/etc/ssl/private/notifier.key

# Set to true when running behind a reverse proxy (enables X-Forwarded-* header trust)
# Leave out (or explicitly set to false) when the app is exposed directly to the internet.
# TRUST_PROXY=false

# Database credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=user123
DB_PASS=password123
DB_NAME=db_name_123
DB_SSLMODE=require # disable/require/verify-full/verify-ca
# Only needed for DB_SSLMODE=verify-full/DB_SSLMODE=verify-ca:
# DB_SSL_CA_CERT=/etc/ssl/certs/db-ca.crt

# Identity providers for OIDC login (JSON array, one object per provider)
# Fields: name (url-safe unique id), display_name (button label), issuer (OIDC discovery URL),
#         client_id, client_secret, scopes (optional, defaults to ["openid","email","profile"])
#
# Common supported providers: Google, GitLab, Microsoft Entra ID, Okta, Auth0, Keycloak, Authentik
# Apple and GitHub are not supported !!!
#
# Example (Google + Authentik):
OIDC_PROVIDERS=[{"name":"google","display_name":"Google","issuer":"https://accounts.google.com","client_id":"XXXX","client_secret":"XXXX"},{"name":"authentik","display_name":"My SSO","issuer":"https://auth.example.com/application/o/notifier/","client_id":"XXXX","client_secret":"XXXX"}]

# Email provider: "resend" or "smtp"
EMAIL_PROVIDER=resend

# Notifications via Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM_ADDR=Nixpkgs Notifier <notify@yourdomain.com>

# Notifications via custom SMTP server
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifier@example.com
SMTP_PASS=yourpassword
SMTP_FROM=notifier@example.com

# CONFIG (overridable at runtime via admin UI):

# Notification dispatcher settings
NOTIFICATION_DISPATCH_INTERVAL=5m #defaults to 5m when left out
NOTIFICATION_MAX_RETRIES=3 #defaults to 3 retries when left out
NOTIFICATION_DISABLE_ON_MAX_RETRIES=true #defaults to true when left out
NOTIFICATION_WORKER_COUNT=2 #defaults to 2 workers when left out

# Periodic package version checker
PACKAGE_CHECK_INTERVAL=12h     # defaults to 12h when left out
PACKAGE_CHECK_WORKER_COUNT=5  # defaults to 5 workers when left out
PACKAGE_CHECK_SKIP_INTERVAL=5m  # defaults to 5m when left out